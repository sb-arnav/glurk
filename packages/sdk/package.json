{
  "name": "@glurk-protocol/sdk",
  "version": "0.1.0",
  "description": "The identity protocol for Solana. Apps trade data. Users own everything.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "solana",
    "identity",
    "credentials",
    "glurk",
    "token-2022",
    "sbt"
  ],
  "author": "Glurk Protocol",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": ">=0.29.0",
    "@solana/web3.js": ">=1.87.0"
  },
  "peerDependenciesMeta": {
    "@coral-xyz/anchor": {
      "optional": true
    }
  }
}
